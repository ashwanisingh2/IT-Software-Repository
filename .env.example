# Database
DATABASE_URL=postgresql://winrepo:changeme@postgres:5432/winrepo
DB_HOST=postgres
DB_PORT=5432
DB_NAME=winrepo
DB_USER=winrepo
DB_PASSWORD=changeme

# Redis
REDIS_URL=redis://:changeme@redis:6379
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=changeme

# MinIO
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=changeme
MINIO_BUCKET=winrepo-packages

# Auth
JWT_ACCESS_SECRET=change-this-to-64-char-random-string
JWT_REFRESH_SECRET=change-this-to-different-64-char-random-string
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d
SESSION_SECRET=change-this-to-32-char-random-string

# GitHub (fallback storage)
GITHUB_TOKEN=ghp_your_token_here
GITHUB_OWNER=your-org
GITHUB_REPO=winrepo-binaries

# App
NODE_ENV=production
API_PORT=4000
API_URL=http://api:4000
NEXT_PUBLIC_API_URL=http://localhost/api
CORS_ORIGIN=http://localhost
