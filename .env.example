# Database Configuration
DATABASE_URL=postgres://winrepo:winrepo_password_secure@postgres:5432/winrepo
DB_HOST=postgres
DB_PORT=5432
DB_NAME=winrepo
DB_USER=winrepo
DB_PASSWORD=winrepo_password_secure

# Redis Configuration
REDIS_URL=redis://redis:6379
REDIS_HOST=redis
REDIS_PORT=6379

# MinIO Configuration
MINIO_ENDPOINT=minio
MINIO_PUBLIC_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin_secure
MINIO_BUCKET=winrepo-packages
MINIO_USE_SSL=false

# Authentication
JWT_SECRET=winrepo_super_secret_jwt_key_here
JWT_ACCESS_SECRET=winrepo_super_secret_jwt_key_here
JWT_REFRESH_SECRET=winrepo_super_secret_refresh_key_here
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d
SESSION_SECRET=winrepo_session_secret

# External Integrations (Optional)
GITHUB_TOKEN=
GITHUB_OWNER=
GITHUB_REPO=

# API & Web App Configuration
PORT=3001
API_PORT=3001
API_URL=http://localhost/api
NEXT_PUBLIC_API_URL=http://localhost/api
NODE_ENV=development
CORS_ORIGIN=http://localhost
