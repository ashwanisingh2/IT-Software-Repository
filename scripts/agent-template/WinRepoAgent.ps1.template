<#
.SYNOPSIS
WinRepo Agent - Auto-generated for deployment
#>

$ErrorActionPreference = "Stop"

# Injected by server
$API_URL = "{{API_URL}}"
$ENROLLMENT_TOKEN = "{{ENROLLMENT_TOKEN}}"

$CONFIG_DIR = "$env:APPDATA\WinRepo"
$CRED_FILE = "$CONFIG_DIR\credentials.dat"
$SCRIPT_PATH = "$CONFIG_DIR\WinRepoAgent.ps1"
$TASK_NAME = "WinRepoAgent"

function Get-MachineId {
    $uuid = (Get-CimInstance -Class Win32_ComputerSystemProduct).UUID
    if (-not $uuid -or $uuid -match "^0{8}-") {
        $mac = (Get-NetAdapter | Where-Object Status -eq 'Up' | Select-Object -First 1).MacAddress
        $uuid = "MAC-$mac"
    }
    return $uuid
}

function Register-Agent {
    if (Test-Path $CRED_FILE) {
        return # Already registered
    }

    Write-Host "Registering with WinRepo..."
    $machineId = Get-MachineId
    $os = Get-CimInstance Win32_OperatingSystem
    $ip = (Get-NetIPAddress -AddressFamily IPv4 -InterfaceAlias "Wi-Fi","Ethernet" -ErrorAction SilentlyContinue | Select-Object -First 1).IPAddress

    $payload = @{
        enrollmentToken = $ENROLLMENT_TOKEN
        machineId = $machineId
        hostname = $env:COMPUTERNAME
        ipAddress = $ip
        osName = $os.Caption
        osVersion = $os.Version
        osArch = $os.OSArchitecture
    } | ConvertTo-Json

    try {
        $response = Invoke-RestMethod -Uri "$API_URL/agent/register" -Method Post -Body $payload -ContentType "application/json"
        
        if ($response.success -and $response.data.apiKey) {
            if (-not (Test-Path $CONFIG_DIR)) { New-Item -ItemType Directory -Path $CONFIG_DIR | Out-Null }
            $secureKey = ConvertTo-SecureString -String $response.data.apiKey -AsPlainText -Force
            $secureKey | ConvertFrom-SecureString | Out-File $CRED_FILE
            Write-Host "Registration successful."
        } else {
            Write-Error "Registration failed. Server returned unexpected response."
        }
    } catch {
        Write-Error "Failed to register endpoint: $_"
    }
}

function Get-ApiKey {
    if (-not (Test-Path $CRED_FILE)) { throw "Not registered. Missing credentials." }
    $secureString = Get-Content $CRED_FILE | ConvertTo-SecureString
    $ptr = [System.Runtime.InteropServices.Marshal]::SecureStringToBSTR($secureString)
    $key = [System.Runtime.InteropServices.Marshal]::PtrToStringAuto($ptr)
    [System.Runtime.InteropServices.Marshal]::ZeroFreeBSTR($ptr)
    return $key
}

function Get-Headers {
    return @{
        "x-machine-id" = Get-MachineId
        "x-machine-key" = Get-ApiKey
        "Content-Type" = "application/json"
    }
}

function Report-Error {
    param($Type, $Message, $Context)
    try {
        $payload = @{ errorType = $Type; message = $Message; context = $Context } | ConvertTo-Json
        Invoke-RestMethod -Uri "$API_URL/agent/error-report" -Method Post -Headers (Get-Headers) -Body $payload -ErrorAction SilentlyContinue
    } catch { }
}

function Submit-Inventory {
    try {
        Write-Host "Submitting inventory..."
        $installed = Get-ItemProperty HKLM:\Software\Wow6432Node\Microsoft\Windows\CurrentVersion\Uninstall\* |
                     Select-Object DisplayName, DisplayVersion, Publisher |
                     Where-Object { $_.DisplayName -ne $null }
        $installed64 = Get-ItemProperty HKLM:\Software\Microsoft\Windows\CurrentVersion\Uninstall\* |
                       Select-Object DisplayName, DisplayVersion, Publisher |
                       Where-Object { $_.DisplayName -ne $null }
                       
        $allSoftware = @()
        foreach ($app in ($installed + $installed64)) {
            $allSoftware += @{
                name = $app.DisplayName
                version = if ($app.DisplayVersion) { $app.DisplayVersion } else { "Unknown" }
                vendor = if ($app.Publisher) { $app.Publisher } else { "Unknown" }
            }
        }
        
        $payload = @{ software = $allSoftware } | ConvertTo-Json -Depth 3
        Invoke-RestMethod -Uri "$API_URL/inventory/endpoints/$(Get-MachineId)/checkin" -Method Post -Headers (Get-Headers) -Body $payload
        Write-Host "Inventory submitted."
    } catch {
        Report-Error -Type "InventoryError" -Message $_.Exception.Message
    }
}

function Check-PendingDeployments {
    try {
        $deployments = (Invoke-RestMethod -Uri "$API_URL/agent/pending-deployments" -Method Get -Headers (Get-Headers)).data
        
        foreach ($dep in $deployments) {
            Write-Host "Processing deployment for $($dep.softwareName)..."
            try {
                $downloadUrl = "$API_URL/software/$($dep.softwareId)/download"
                $tempFile = "$env:TEMP\winrepo_install_$($dep.softwareId).exe"
                
                Invoke-WebRequest -Uri $downloadUrl -OutFile $tempFile
                
                $args = if ($dep.silentInstallArgs) { $dep.silentInstallArgs } else { "/S" }
                
                $proc = Start-Process -FilePath $tempFile -ArgumentList $args -Wait -PassThru -NoNewWindow
                
                if ($proc.ExitCode -eq 0) {
                    $payload = @{ deploymentId = $dep.id; status = "completed" } | ConvertTo-Json
                    Invoke-RestMethod -Uri "$API_URL/agent/deployment-result" -Method Post -Headers (Get-Headers) -Body $payload
                } else {
                    $payload = @{ deploymentId = $dep.id; status = "failed"; errorMessage = "Exit code $($proc.ExitCode)" } | ConvertTo-Json
                    Invoke-RestMethod -Uri "$API_URL/agent/deployment-result" -Method Post -Headers (Get-Headers) -Body $payload
                }
                
                Remove-Item $tempFile -Force
            } catch {
                $payload = @{ deploymentId = $dep.id; status = "failed"; errorMessage = $_.Exception.Message } | ConvertTo-Json
                Invoke-RestMethod -Uri "$API_URL/agent/deployment-result" -Method Post -Headers (Get-Headers) -Body $payload
            }
        }
    } catch {
        Report-Error -Type "DeploymentError" -Message $_.Exception.Message
    }
}

function Install-ScheduledTask {
    if (-not (Get-ScheduledTask -TaskName $TASK_NAME -ErrorAction SilentlyContinue)) {
        Write-Host "Installing Scheduled Task..."
        if (-not (Test-Path $SCRIPT_PATH)) {
            Copy-Item $PSCommandPath -Destination $SCRIPT_PATH -Force
        }
        
        $action = New-ScheduledTaskAction -Execute "powershell.exe" -Argument "-ExecutionPolicy Bypass -WindowStyle Hidden -File `"$SCRIPT_PATH`""
        $trigger = New-ScheduledTaskTrigger -Once -At (Get-Date) -RepetitionInterval (New-TimeSpan -Hours 6)
        Register-ScheduledTask -TaskName $TASK_NAME -Action $action -Trigger $trigger -User "SYSTEM" -RunLevel Highest -Force
        Write-Host "Task installed."
    }
}

# MAIN EXECUTION
try {
    Register-Agent
    Install-ScheduledTask
    Submit-Inventory
    Check-PendingDeployments
} catch {
    Write-Error $_
}
